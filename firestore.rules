rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to all collections
    match /{document=**} {
      allow read: if true;
    }

    // Allow write access only to authenticated users (Administrators)
    match /{document=**} {
      allow write: if request.auth != null;
    }
    
    // Specifically for news, blog, and recipes, ensure only editors/admins can write
    // This can be expanded based on your specific RBAC needs
    match /recipes/{recipeId} {
      allow write: if request.auth != null;
    }
    
    match /blogs/{blogId} {
      allow write: if request.auth != null;
    }
    
    match /news/{newsId} {
      allow write: if request.auth != null;
    }
  }
}
